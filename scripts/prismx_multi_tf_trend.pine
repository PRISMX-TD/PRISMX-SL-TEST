//@version=5
indicator("PRISMX 多周期趋势", overlay=true)

// ===== 1) 配置 =====
SECRET   = "rdE8ErRCa43EBonEHmdOmfmmxJRj7SfQJYImSST4YBQ"  // 与服务器 .env 的 WEBHOOK_SECRET 一致
fastLen  = input.int(10, "快线周期")
slowLen  = input.int(30, "慢线周期")
slopeLen = input.int(3,  "斜率回看根数")           // 慢线与几根前比较，判断斜率方向
sendMode = input.string("变化时发送", "发送方式", options=["变化时发送", "每根收盘发送"])

// ===== 2) 单周期趋势：均线排列 + 斜率 =====
// UP  : 收盘 > 慢线 且 快线 > 慢线 且 慢线斜率向上
// DOWN: 收盘 < 慢线 且 快线 < 慢线 且 慢线斜率向下
// FLAT: 其余（震荡/无趋势 -> 前端记为观望）
f_trend(tf) =>
    c        = request.security(syminfo.tickerid, tf, close,                        lookahead=barmerge.lookahead_off)
    fast     = request.security(syminfo.tickerid, tf, ta.ema(close, fastLen),       lookahead=barmerge.lookahead_off)
    slow     = request.security(syminfo.tickerid, tf, ta.ema(close, slowLen),       lookahead=barmerge.lookahead_off)
    slowPrev = request.security(syminfo.tickerid, tf, ta.ema(close, slowLen)[slopeLen], lookahead=barmerge.lookahead_off)
    up   = c > slow and fast > slow and slow > slowPrev
    down = c < slow and fast < slow and slow < slowPrev
    up ? "UP" : down ? "DOWN" : "FLAT"

t5   = f_trend("5")
t15  = f_trend("15")
t30  = f_trend("30")
t60  = f_trend("60")
t240 = f_trend("240")

// ===== 3) 组合与变化判定 =====
combo   = t5 + "|" + t15 + "|" + t30 + "|" + t60 + "|" + t240
changed = combo != combo[1]

// ===== 4) 拼 JSON =====
f_json() =>
    s = '{"secret":"' + SECRET + '",'
    s := s + '"symbol":"' + syminfo.ticker + '",'
    s := s + '"trends":{'
    s := s + '"M5":"'  + t5   + '",'
    s := s + '"M15":"' + t15  + '",'
    s := s + '"M30":"' + t30  + '",'
    s := s + '"H1":"'  + t60  + '",'
    s := s + '"H4":"'  + t240 + '"},'
    s := s + '"id":"' + syminfo.ticker + '-' + str.tostring(time) + '"}'
    s

// ===== 5) 发送：满足条件时用 alert() 发合法 JSON =====
doSend = barstate.isconfirmed and (sendMode == "每根收盘发送" or changed)
if doSend
    alert(f_json(), alert.freq_once_per_bar_close)

// ===== 6) 可视参考 =====
plot(ta.ema(close, fastLen), "EMA快",  color=color.aqua)
plot(ta.ema(close, slowLen), "EMA慢", color=color.orange)

// 右上角五周期方向表 / multi-TF direction table
dirColor(d) => d == "UP" ? color.new(#2fe6a0, 0) : d == "DOWN" ? color.new(#ff4d6d, 0) : color.new(#94a3b8, 0)
dirArrow(d) => d == "UP" ? "↑" : d == "DOWN" ? "↓" : "→"
var table tb = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(tb, 0, 0, "周期", text_color=color.gray,   text_size=size.small)
    table.cell(tb, 1, 0, "方向", text_color=color.gray,   text_size=size.small)
    table.cell(tb, 0, 1, "M5",  text_color=color.silver, text_size=size.small)
    table.cell(tb, 1, 1, dirArrow(t5),   text_color=dirColor(t5),   text_size=size.small)
    table.cell(tb, 0, 2, "M15", text_color=color.silver, text_size=size.small)
    table.cell(tb, 1, 2, dirArrow(t15),  text_color=dirColor(t15),  text_size=size.small)
    table.cell(tb, 0, 3, "M30", text_color=color.silver, text_size=size.small)
    table.cell(tb, 1, 3, dirArrow(t30),  text_color=dirColor(t30),  text_size=size.small)
    table.cell(tb, 0, 4, "H1",  text_color=color.silver, text_size=size.small)
    table.cell(tb, 1, 4, dirArrow(t60),  text_color=dirColor(t60),  text_size=size.small)
    table.cell(tb, 0, 5, "H4",  text_color=color.silver, text_size=size.small)
    table.cell(tb, 1, 5, dirArrow(t240), text_color=dirColor(t240), text_size=size.small)
