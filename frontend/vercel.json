{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/proxy/myfxbook", "destination": "/api/proxy/myfxbook" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/proxy/myfxbook.ts": {
      "memory": 256,
      "maxDuration": 15
    }
  }
}
